{
    "name": "myndra.plugin.markdown-adapter",
    "displayName": "Markdown Adapter",
    "version": "0.1.0",
    "engine": ">=0.0.0",
    "description": "Syntax highlighting and file tagging for Markdown files",
    "entry": "./dist/index.js",
    "author": "Lucas Müller",
    "category": "reference-example",
    "permissions": [
        "editor:register",
        "filepreview:register",
        "treesitter:parse",
        "glyphs:register",
        "hierarchy:register",
        "fileindex:register",
        "graph:read",
        "graph:write",
        "graph:session",
        "filesystem:read"
    ],
    "grammar": {
        "fileExtensions": [
            ".md",
            ".markdown"
        ],
        "wasmPath": "./assets/tree-sitter-markdown.wasm",
        "languageName": "markdown"
    }
}
